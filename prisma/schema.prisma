generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Project {
  id        String   @id @default(cuid())
  code      String   @unique
  name      String
  deadline  DateTime
  createdAt DateTime @default(now())
  tasks     Task[]
}

model Task {
  id          String    @id @default(cuid())
  projectId   String
  project     Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  phase       String
  phaseKey    String
  name        String
  offset      Int       @default(0)
  due         DateTime
  done        Boolean   @default(false)
  completedAt DateTime?
  note        String    @default("")
  ownerUnit   String?
  requiredDocs String?
  createdAt   DateTime  @default(now())
}
