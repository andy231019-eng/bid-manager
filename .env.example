# Copy this file to .env and fill in your values

# === Vercel Postgres (Neon) ===
# DATABASE_URL="postgres://[user]:[password]@[host]/[db]?sslmode=require"

# === Supabase ===
# DATABASE_URL="postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres"

# === Local PostgreSQL ===
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/bid_manager?schema=public"

# NOTE: DIRECT_URL is only needed if your provider uses PgBouncer connection pooling
# (e.g. Neon serverless driver). For Supabase or plain PostgreSQL, DATABASE_URL is enough.
# If needed, add directUrl = env("DIRECT_URL") back to prisma/schema.prisma and set:
# DIRECT_URL="postgresql://..."
