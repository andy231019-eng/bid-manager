# Copy this file to .env and fill in your values

# === Vercel Postgres (Neon) ===
# DATABASE_URL="postgres://[user]:[password]@[host]/[db]?sslmode=require"      # pooled
# DIRECT_URL="postgres://[user]:[password]@[host]/[db]?sslmode=require"        # direct (non-pooled)

# === Supabase ===
# DATABASE_URL="postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres"
# DIRECT_URL="postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres"

# === Local PostgreSQL ===
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/bid_manager?schema=public"
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/bid_manager?schema=public"
